# Copy to .env and fill in. Never commit .env.

# Safety
TEST_MODE=true

# Supabase (own project - not shared with the OKX app)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# IC Markets MT5 demo account.
#
# FILL THESE IN. Left blank, the engine attaches to whatever terminal is open on
# whatever account it happens to be logged into, and cannot log back in if that
# changes underneath it. That is not hypothetical: it cost two hours of silent
# order rejections on 2026-07-15 (see docs/safety-rails.md).
#
#   MT5_LOGIN / MT5_PASSWORD  - pin the ACCOUNT. Without them the engine binds to
#                               the first account it sees and can only refuse, not
#                               recover, when the terminal moves.
#   MT5_TERMINAL_PATH         - pin the TERMINAL. Required once a second (live)
#                               terminal exists, or the demo engine can attach to
#                               the live one and trade real money as "demo".
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TERMINAL_PATH=

# Telegram (new bot - not shared with the OKX app)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI provider (Phase 5)
ANTHROPIC_API_KEY=
